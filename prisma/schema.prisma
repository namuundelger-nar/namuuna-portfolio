// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Profile {
  id        String   @id @default(cuid())
  name      String
  title     String
  bio       String
  email     String
  phone     String?
  location  String?
  github    String?
  linkedin  String?
  twitter   String?
  resumeUrl String?  // URL to download CV
  imageUrl  String?  // Profile picture URL
  updatedAt DateTime @updatedAt
}

model Experience {
  id          String   @id @default(cuid())
  company     String
  role        String
  startDate   String
  endDate     String?  // null if current
  location    String?
  description String
  techStack   String   // comma separated tags
  order       Int      @default(0) // For sorting
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id          String   @id @default(cuid())
  title       String
  description String
  link        String?
  github      String?
  techStack   String   // comma separated tags
  featured    Boolean  @default(false)
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Skill {
  id        String   @id @default(cuid())
  category  String   // e.g. Frontend, Backend, Tools
  name      String
  order     Int      @default(0)
}

model Education {
  id          String   @id @default(cuid())
  institution String
  degree      String
  startDate   String
  endDate     String?
  location    String?
  description String?
  order       Int      @default(0)
}

model Certification {
  id        String   @id @default(cuid())
  name      String
  issuer    String
  date      String?
  link      String?
  badgeId   String?
  order     Int      @default(0)
}

model BlogPost {
  id         String   @id @default(cuid())
  title      String
  slug       String   @unique
  content    String   // Markdown or HTML
  coverImage String?  // Hero/stock image URL
  published Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Free-form inline-editable text, addressed by a stable key (e.g. "home.quote").
model ContentBlock {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
  revisions ContentRevision[]
}

// Append-only history of every published edit, for audit/rollback.
model ContentRevision {
  id        String   @id @default(cuid())
  blockKey  String
  value     String
  createdAt DateTime @default(now())
  block     ContentBlock @relation(fields: [blockKey], references: [key])
}

model MediaAsset {
  id        String   @id @default(cuid())
  filename  String
  url       String
  alt       String?
  mimeType  String
  createdAt DateTime @default(now())
}

model DesignConfig {
  id              String   @id @default(cuid())
  primaryColor    String   @default("#fafafa")
  backgroundColor String   @default("#09090b")
  textColor       String   @default("#fafafa")
  borderRadius    String   @default("0.5rem")
  updatedAt       DateTime @updatedAt
}
